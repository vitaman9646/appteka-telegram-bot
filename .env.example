# Telegram Bot Tokens (создай через @BotFather)
BOT_TOKEN_MAIN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN_GAMES=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN_TOOLS=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN_PREMIUM=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Channel IDs (создай каналы, добавь ботов как админов)
CHANNEL_MAIN=@your_main_channel
CHANNEL_GAMES=@your_games_channel
CHANNEL_TOOLS=@your_tools_channel
CHANNEL_PREMIUM=@your_premium_channel

# Настройки парсинга
PARSE_INTERVAL_MINUTES=30
FILTER_HOURS=24
MIN_DOWNLOADS=5

# OpenAI API (опционально, для AI-описаний)
OPENAI_API_KEY=sk-...
USE_AI_DESCRIPTIONS=false
