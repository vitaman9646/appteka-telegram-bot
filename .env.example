# ==============================================
# APPTEKA TELEGRAM BOT - Конфигурация (3 канала)
# ==============================================

# ============ ИГРЫ ============
# Создай бота через @BotFather
BOT_TOKEN_GAMES=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Создай канал, добавь бота как админа
# Формат: @channel_username или -100123456789
CHANNEL_GAMES=@your_games_channel


# ============ ПРЕМИУМ ============
BOT_TOKEN_PREMIUM=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
CHANNEL_PREMIUM=@your_premium_channel


# ============ МЕДИА (музыка/видео) ============
BOT_TOKEN_MEDIA=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
CHANNEL_MEDIA=@your_media_channel


# ============ НАСТРОЙКИ ПАРСИНГА ============
# Как часто парсить новые приложения (в минутах)
PARSE_INTERVAL_MINUTES=30

# За какой период показывать новые приложения (в часах)
FILTER_HOURS=24

# Минимум скачиваний (фильтр мусора)
MIN_DOWNLOADS=3


# ============ AI (ОПЦИОНАЛЬНО) ============
# Если хочешь AI-описания через OpenAI/ChatGPT
# Оставь false, если не нужно
USE_AI_DESCRIPTIONS=false
OPENAI_API_KEY=sk-...
